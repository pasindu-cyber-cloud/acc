<Page x:Class="ProcAI.App.Views.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <StackPanel Margin="24">
        <TextBlock Text="Reports" FontSize="24" FontWeight="Bold" Margin="0,0,0,12" />
        <Border Background="#1A222C" CornerRadius="12" Padding="16">
            <StackPanel>
                <TextBlock Text="Export data" FontSize="16" FontWeight="Bold" />
                <TextBlock Text="Reports are generated locally and saved to your reports folder. No data leaves this machine."
                           Opacity="0.7" FontSize="12" Margin="0,4,0,12" TextWrapping="Wrap" />
                <WrapPanel>
                    <ui:Button Content="Export alerts (CSV)" Margin="0,0,8,8" Click="OnAlertsCsv" />
                    <ui:Button Content="Export alerts (PDF)" Margin="0,0,8,8" Click="OnAlertsPdf" />
                    <ui:Button Content="Export process history (CSV)" Margin="0,0,8,8" Click="OnHistoryCsv" />
                    <ui:Button Content="Open reports folder" Margin="0,0,8,8" Click="OnOpenFolder" />
                </WrapPanel>
                <TextBlock x:Name="StatusText" Foreground="#2ECC71" Margin="0,8,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
