<ui:FluentWindow x:Class="ProcAI.App.Views.ConsentWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Welcome to ProcAI - Consent &amp; Transparency"
                 Width="640" Height="640"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="ProcAI" />

        <StackPanel Grid.Row="1" Margin="24,12,24,0">
            <TextBlock Text="🛡 Welcome to ProcAI" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="Transparent, defensive process monitoring" Opacity="0.7" Margin="0,4,0,0" />
        </StackPanel>

        <Border Grid.Row="2" Margin="24,16,24,16" CornerRadius="8"
                Background="#22000000" Padding="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                <TextBlock TextWrapping="Wrap" LineHeight="20" x:Name="ConsentText" />
            </ScrollViewer>
        </Border>

        <CheckBox Grid.Row="3" x:Name="AgreeCheck" Margin="24,0,24,8"
                  Content="I understand and consent to local process monitoring."
                  Checked="OnAgreeChanged" Unchecked="OnAgreeChanged" />

        <Grid Grid.Row="4" Margin="24,0,24,20">
            <ui:Button Content="Decline &amp; Exit" HorizontalAlignment="Left" Click="OnDecline" />
            <ui:Button x:Name="AcceptButton" Content="Accept &amp; Continue" Appearance="Primary"
                       HorizontalAlignment="Right" IsEnabled="False" Click="OnAccept" />
        </Grid>
    </Grid>
</ui:FluentWindow>
