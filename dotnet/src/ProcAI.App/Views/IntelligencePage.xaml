<Page x:Class="ProcAI.App.Views.IntelligencePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Process Intelligence" FontSize="24" FontWeight="Bold" Margin="0,0,0,12" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="PID:" VerticalAlignment="Center" Opacity="0.7" />
            <ui:TextBox x:Name="PidBox" Width="140" Margin="8,0" PlaceholderText="e.g. 1234" />
            <ui:Button Content="Inspect" Click="OnInspect" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#1A222C" CornerRadius="12" Padding="14" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Explanation" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                    <TextBox x:Name="Explanation" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" Background="#222C38" BorderThickness="0"
                             Text="Enter a PID and click Inspect." />
                </DockPanel>
            </Border>
            <Border Grid.Column="1" Background="#1A222C" CornerRadius="12" Padding="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Investigation Guide" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                    <ItemsControl x:Name="Guide">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#222C38" CornerRadius="8" Padding="10" Margin="0,3">
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
