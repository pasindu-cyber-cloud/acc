<Page x:Class="ProcAI.App.Views.ProtectionHealthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="Protection Health" FontSize="24" FontWeight="Bold" Margin="0,0,0,12" />

            <Border Background="#1A222C" CornerRadius="12" Padding="18" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🛡" FontSize="40" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="BannerTitle" Text="Checking..." FontSize="22" FontWeight="Bold" />
                        <TextBlock x:Name="BannerSub" Opacity="0.7" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <ItemsControl x:Name="StatusList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1A222C" CornerRadius="10" Padding="12" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="●" Foreground="{Binding DotBrush}" FontSize="16" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="{Binding Label}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding Value}" Foreground="{Binding DotBrush}" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Margin="0,8,0,0" Opacity="0.6" TextWrapping="Wrap"
                       Text="ProcAI is independent software and does not replace or impersonate Microsoft Defender. Keep Windows Defender enabled." />
        </StackPanel>
    </ScrollViewer>
</Page>
