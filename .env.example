# =============================================================================
# AccuScan environment configuration
# Copy to .env and fill in. NEVER commit your real .env.
# =============================================================================

# --- Deriv connection -------------------------------------------------------
# Register an app at https://api.deriv.com to obtain an app_id.
# The public market-data scanner works WITHOUT a token.
DERIV_APP_ID=1089
DERIV_WS_URL=wss://ws.derivws.com/websockets/v3

# API token is ONLY required for demo/live execution (NOT for analytics/paper).
# Create a token at https://app.deriv.com/account/api-token
# Scopes: read, trade (add 'payments'/'admin' are NOT needed and discouraged).
# Use a DEMO account token while testing. LEAVE BLANK for analytics/paper mode.
DERIV_API_TOKEN=

# Account currency used for proposals.
DERIV_CURRENCY=USD

# --- Runtime mode -----------------------------------------------------------
# One of: analytics | paper | demo | live
# Default is analytics. 'live' additionally requires ACCUSCAN_LIVE_CONFIRM=I_UNDERSTAND_THE_RISK
ACCUSCAN_MODE=analytics
ACCUSCAN_RISK_PROFILE=conservative
ACCUSCAN_LIVE_CONFIRM=

# --- Data source ------------------------------------------------------------
# deriv  -> connect to real Deriv WS (requires network)
# mock   -> offline synthetic tick generator (no network; for dev/testing)
ACCUSCAN_DATA_SOURCE=mock

# Optional explicit watchlist (comma separated). If empty, symbols are
# discovered dynamically via active_symbols + contracts_for.
ACCUSCAN_SYMBOLS=

# --- Storage ----------------------------------------------------------------
ACCUSCAN_DB_URL=sqlite:///storage/accuscan.db
ACCUSCAN_LOG_LEVEL=INFO

# --- Dashboard --------------------------------------------------------------
ACCUSCAN_DASHBOARD_HOST=127.0.0.1
ACCUSCAN_DASHBOARD_PORT=8000
